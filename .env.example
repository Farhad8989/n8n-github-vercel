# ============================================================
# AI Video Generator - Environment Variables Template
# Copy this file to .env.local for local development
# Set these in Vercel dashboard for production
# ============================================================

# n8n Webhook URLs
# Get these after activating your workflows in n8n Cloud
N8N_GENERATE_WEBHOOK_URL=https://your-instance.app.n8n.cloud/webhook/generate-video
N8N_STATUS_WEBHOOK_URL=https://your-instance.app.n8n.cloud/webhook/check-status

# Leonardo.ai API Key
# Get your key at: https://app.leonardo.ai/settings/api
# The Next.js API route uses this to upload images to S3 before passing the imageId to n8n
LEONARDO_API_KEY=your-leonardo-api-key-here
